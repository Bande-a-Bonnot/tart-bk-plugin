#!/usr/bin/env bash
set -euo pipefail

HOOKS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/shared.bash
. "${HOOKS_DIR}/../lib/shared.bash"
read_state

SSH_USERNAME="$(plugin_var_default SSH_USERNAME admin)"
SSH_PASSWORD="$(plugin_var_default SSH_PASSWORD admin)"
DOPPLER_TOKEN_PATH="$(plugin_var DOPPLER_TOKEN_PATH || true)"
if [ -z "${DOPPLER_TOKEN_PATH}" ]; then
  log "FATAL: plugin config 'doppler_token_path' is required"
  exit 1
fi
if [ ! -r "${DOPPLER_TOKEN_PATH}" ]; then
  log "FATAL: Doppler token path unreadable: ${DOPPLER_TOKEN_PATH}"
  exit 1
fi
if [ -z "${HOST_SCRATCH:-}" ] || [ ! -d "${HOST_SCRATCH}" ]; then
  log "FATAL: host scratch missing; pre-command did not initialize state"
  exit 1
fi

VM_IP="$(tart ip --wait 60 "${VM_NAME}")"
log "VM ${VM_NAME} IP=${VM_IP}; waiting for SSH"

SSH_OPTS=()
while IFS= read -r opt; do SSH_OPTS+=("${opt}"); done < <(ssh_opts)

for _ in $(seq 1 30); do
  if sshpass -p "${SSH_PASSWORD}" ssh "${SSH_OPTS[@]}" -o ConnectTimeout=2 \
      "${SSH_USERNAME}@${VM_IP}" "true" >/dev/null 2>&1; then
    ssh_ready=1
    break
  fi
  sleep 1
done
if [ "${ssh_ready:-0}" != "1" ]; then
  log "FATAL: SSH not available after 30 attempts"
  exit 13
fi

shell_quote() {
  python3 -c 'import shlex,sys; sys.stdout.write(shlex.quote(sys.stdin.read()))'
}

ENV_FILE="${HOST_SCRATCH}/.env.sh"
CMD_FILE="${HOST_SCRATCH}/.cmd.sh"
: >"${ENV_FILE}"
chmod 600 "${ENV_FILE}"
{
  echo '# Generated by foundry Tart plugin. Contains only forwarded short-lived job/session env.'
  echo 'export FOUNDRY_VM_ISOLATED=1'
  while IFS= read -r key; do
    [ -z "${key}" ] && continue
    case "${key}" in
      *[!A-Za-z0-9_]*|[0-9]*) log "FATAL: invalid forward_env name: ${key}"; exit 1 ;;
    esac
    value="${!key:-}"
    quoted="$(printf '%s' "${value}" | shell_quote)"
    printf 'export %s=%s\n' "${key}" "${quoted}"
  done < <(plugin_array FORWARD_ENV)
} >"${ENV_FILE}"

cat >"${CMD_FILE}" <<EOF
#!/usr/bin/env bash
set -euo pipefail
cd /tmp/scratch/checkout
${BUILDKITE_COMMAND:-}
EOF
chmod 700 "${CMD_FILE}"

# Guard the core invariant: staged files may contain short-lived BK/prompt
# tokens, but never the Doppler bootstrap token or GitHub App PEM.
if grep -E 'DOPPLER_TOKEN|PRIVATE_KEY|BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY' "${ENV_FILE}" "${CMD_FILE}" >/dev/null 2>&1; then
  log "FATAL: staged command/env contains a forbidden long-lived secret marker"
  exit 1
fi

log "executing command in VM via SSH-stdin bootstrap"
doppler_token="$(cat "${DOPPLER_TOKEN_PATH}")"
set +e
sshpass -p "${SSH_PASSWORD}" ssh "${SSH_OPTS[@]}" \
  "${SSH_USERNAME}@${VM_IP}" \
  "/usr/local/bin/foundry-vm-bootstrap /tmp/scratch/.cmd.sh /tmp/scratch/.env.sh" <<EOF
${doppler_token}
EOF
ssh_ec=$?
set -e
unset doppler_token
exit "${ssh_ec}"
